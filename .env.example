# ======================
# SPRING PROFILE
# ======================
SPRING_PROFILE=dev

# ======================
# DATABASE CONFIG - SUPABASE
# ======================
# MS-SCHEDULE (Horarios y Disponibilidad)
# Reemplaza con tu URL de Transaction Pooler de Supabase
DB_URL=jdbc:postgresql://aws-1-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DB_USER=postgres.[TU-PROJECT-REF]
DB_PASSWORD=[TU-CONTRASEÑA-DE-SUPABASE]

# ======================
# JWT CONFIG (MISMO VALOR EN TODOS LOS MS)
# ======================
# Genera un token seguro con: openssl rand -base64 64
# DEBE SER EL MISMO VALOR EN TODOS LOS MICROSERVICIOS
JWT_SECRET=[TU-JWT-SECRET-SEGURA]
JWT_EXPIRATION=86400000

# ======================
# EXTERNAL SERVICES URLs
# ======================
# URLs de los otros microservicios
SERVICES_AUTH_URL=http://localhost:8081
SERVICES_CATALOG_URL=http://localhost:8082
SERVICES_SCHEDULE_URL=http://localhost:8083

# ======================
# FRONTEND URL
# ======================
# URL del frontend para los enlaces
FRONTEND_URL=http://localhost:3000